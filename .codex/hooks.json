{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\Babis\\Desktop\\Glowishes AI\\.codex\\hooks\\glowishes-policy.ps1\"",
            "timeout": 5,
            "statusMessage": "Loading Glowishes rules"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
