      "updated": 1779091789373,
      "link": null,
      "locked": false,
      "text": "Αυτός ο Agent\nδιευθύνη το\nMarketing του\nEshop μαζι με\nτην ομάδα του, ",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
